{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start app",
            "type": "shell",
            "command": ".\\run-backend.cmd",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Start frontend only",
            "type": "shell",
            "command": "node frontend/server.mjs",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Open app in browser",
            "type": "shell",
            "command": "Start-Process http://localhost:8080/",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Seed demo data",
            "type": "shell",
            "command": "node scripts/seed-demo-data.mjs",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Run backend tests",
            "type": "shell",
            "command": ".\\run-backend-tests.cmd",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
